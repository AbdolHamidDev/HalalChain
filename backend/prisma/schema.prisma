generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  avatarUrl      String?  @map("avatar_url")
  avatarPublicId String?  @map("avatar_public_id")
  createdAt    DateTime @default(now()) @map("created_at")

  auditLogs              AuditLog[]
  inventoryMovements     InventoryMovement[]
  notifications          Notification[]
  invitationsSent        UserInvitation[]        @relation("InvitedBy")
  notificationPreference NotificationPreference?
  refreshTokens      RefreshToken[]

  isVerified Boolean @default(false) @map("is_verified")
  status     UserStatus @default(ACTIVE)
  lastLoginAt DateTime? @map("last_login_at")
  tokenVersion Int @default(0) @map("token_version")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique              // stores bcrypt hash of the raw token
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Supplier {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  country           String
  email             String?
  phone             String?
  status            SupplierStatus     @default(ACTIVE)
  createdAt         DateTime           @default(now()) @map("created_at")
  halalCertificates HalalCertificate[]
  products          Product[]
  purchaseOrders    PurchaseOrder[]

  @@map("suppliers")
}

model HalalCertificate {
  id                String   @id @default(uuid()) @db.Uuid
  supplierId        String   @map("supplier_id") @db.Uuid
  certificateNumber String   @map("certificate_number")
  issuedBy          String   @map("issued_by")
  issueDate         DateTime @map("issue_date") @db.Date
  expiryDate        DateTime @map("expiry_date") @db.Date
  fileUrl           String?  @map("file_url")
  filePublicId      String?  @map("file_public_id")
  createdAt         DateTime @default(now()) @map("created_at")
  supplier          Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([expiryDate])
  @@map("halal_certificates")
}

model Product {
  id                 String              @id @default(uuid()) @db.Uuid
  supplierId         String              @map("supplier_id") @db.Uuid
  name               String
  sku                String              @unique
  category           String
  unit               String
  unitPrice          Decimal             @default(0) @map("unit_price") @db.Decimal(12, 2)
  createdAt          DateTime            @default(now()) @map("created_at")
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrderItems PurchaseOrderItem[]

  @@index([supplierId])
  @@map("products")
}

model Warehouse {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  location           String
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]

  @@map("warehouses")
}

model Inventory {
  id           String    @id @default(uuid()) @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  warehouseId  String    @map("warehouse_id") @db.Uuid
  quantity     Int       @default(0)
  reorderLevel Int       @default(10) @map("reorder_level")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@map("inventory")
}

model InventoryMovement {
  id          String                @id @default(uuid()) @db.Uuid
  productId   String                @map("product_id") @db.Uuid
  warehouseId String                @map("warehouse_id") @db.Uuid
  type        InventoryMovementType
  quantity    Int
  note        String?
  performedBy String?               @map("performed_by") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")
  user        User?                 @relation(fields: [performedBy], references: [id])
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId, warehouseId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @db.Uuid
  supplierId  String              @map("supplier_id") @db.Uuid
  poNumber    String              @unique @map("po_number")
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @map("total_amount") @db.Decimal(14, 2)
  createdAt   DateTime            @default(now()) @map("created_at")
  items       PurchaseOrderItem[]
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  shipments   Shipment[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model Shipment {
  id               String         @id @default(uuid()) @db.Uuid
  purchaseOrderId  String         @map("purchase_order_id") @db.Uuid
  trackingNumber   String         @map("tracking_number")
  origin           String
  destination      String
  status           ShipmentStatus @default(PENDING)
  estimatedArrival DateTime?      @map("estimated_arrival")
  shippedAt        DateTime?      @map("shipped_at")
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([status])
  @@map("shipments")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  quantity        Int
  unitPrice       Decimal       @map("unit_price") @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  createdAt  DateTime    @default(now()) @map("created_at")
  user       User?       @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @map("user_id") @db.Uuid
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model UserInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  email       String
  role        UserRole  @default(STAFF)
  token       String    @unique
  invitedBy   String    @map("invited_by") @db.Uuid
  acceptedAt  DateTime? @map("accepted_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  inviter     User      @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([email])
  @@map("user_invitations")
}

model NotificationPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  certificateAlerts Boolean  @default(true) @map("certificate_alerts")
  inventoryAlerts   Boolean  @default(true) @map("inventory_alerts")
  shipmentAlerts    Boolean  @default(true) @map("shipment_alerts")
  invitationEmails  Boolean  @default(true) @map("invitation_emails")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SHIPPING
  RECEIVED
  CANCELLED
  PARTIAL
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  DELAYED
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

enum NotificationType {
  LOW_STOCK
  CERTIFICATE_EXPIRING
  SHIPMENT_DELAYED
  SYSTEM
}
