generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  avatarUrl      String?  @map("avatar_url")
  avatarPublicId String?  @map("avatar_public_id")
  createdAt    DateTime @default(now()) @map("created_at")

  auditLogs              AuditLog[]
  inventoryMovements     InventoryMovement[]
  notifications          Notification[]
  invitationsSent        UserInvitation[]        @relation("InvitedBy")
  notificationPreference NotificationPreference?
  refreshTokens          RefreshToken[]

  // PO approval workflow
  purchaseOrderApprovals PurchaseOrderApproval[]

  isVerified  Boolean    @default(false) @map("is_verified")
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")
  tokenVersion Int       @default(0) @map("token_version")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique              // stores bcrypt hash of the raw token
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// SUPPLIERS  (enhanced with contacts + rating)
// ─────────────────────────────────────────────

model Supplier {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  country           String
  email             String?
  phone             String?
  address           String?
  website           String?
  taxId             String?            @map("tax_id")
  status            SupplierStatus     @default(ACTIVE)
  /// Computed compliance rating 0-100, updated by automation engine
  complianceScore   Int?               @map("compliance_score")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  halalCertificates HalalCertificate[]
  purchaseOrders    PurchaseOrder[]
  contacts          SupplierContact[]
  products          Product[]

  // M:N  Supplier ↔ Product  (a product can have multiple suppliers)
  supplierProducts  SupplierProduct[]

  @@map("suppliers")
}

/// Multiple contacts per supplier (M:1 Supplier)
model SupplierContact {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  name       String
  role       String?                          // e.g. "Sales Manager", "QA Lead"
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_contacts")
}

model HalalCertificate {
  id                String   @id @default(uuid()) @db.Uuid
  supplierId        String   @map("supplier_id") @db.Uuid
  certificateNumber String   @map("certificate_number")
  issuedBy          String   @map("issued_by")
  issueDate         DateTime @map("issue_date") @db.Date
  expiryDate        DateTime @map("expiry_date") @db.Date
  fileUrl           String?  @map("file_url")
  filePublicId      String?  @map("file_public_id")
  createdAt         DateTime @default(now()) @map("created_at")
  supplier          Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // M:N  HalalCertificate ↔ Product  (a certificate can cover multiple products)
  productCertifications ProductCertification[]

  @@index([supplierId])
  @@index([expiryDate])
  @@map("halal_certificates")
}

// ─────────────────────────────────────────────
// PRODUCTS  (with versioning + multi-supplier)
// ─────────────────────────────────────────────

model Product {
  id                 String              @id @default(uuid()) @db.Uuid
  /// Legacy single-supplier FK kept for backward compat; prefer supplierProducts for new logic
  supplierId         String              @map("supplier_id") @db.Uuid
  name               String
  sku                String              @unique
  category           String
  unit               String
  unitPrice          Decimal             @default(0) @map("unit_price") @db.Decimal(12, 2)
  description        String?
  barcode            String?             @unique
  weightKg           Decimal?            @map("weight_kg") @db.Decimal(8, 3)
  /// Current active version number (denormalised for fast reads)
  currentVersion     Int                 @default(1) @map("current_version")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  batchLots          BatchLot[]

  // M:N  Product ↔ Supplier  (multi-sourcing)
  supplierProducts   SupplierProduct[]

  // M:N  Product ↔ HalalCertificate
  productCertifications ProductCertification[]

  // Version history
  versions           ProductVersion[]

  // M:N  Product ↔ Tag
  productTags        ProductTag[]

  @@index([supplierId])
  @@index([isActive])
  @@map("products")
}

/// Immutable snapshot of a product's attributes at a point in time.
/// Created automatically whenever a product is updated.
model ProductVersion {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  version     Int                                    // monotonically increasing
  name        String
  sku         String
  category    String
  unit        String
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  description String?
  changedBy   String?  @map("changed_by") @db.Uuid  // userId
  changeNote  String?  @map("change_note")
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
  @@index([productId])
  @@map("product_versions")
}

/// Junction table: Product ↔ Supplier  (M:N with pricing metadata)
/// Represents "this supplier can supply this product at this price with this lead time"
model SupplierProduct {
  id              String          @id @default(uuid()) @db.Uuid
  supplierId      String          @map("supplier_id") @db.Uuid
  productId       String          @map("product_id") @db.Uuid
  supplierSku     String?         @map("supplier_sku")   // supplier's own SKU for this product
  unitCost        Decimal         @map("unit_cost") @db.Decimal(12, 2)
  currency        String          @default("USD")
  leadTimeDays    Int?            @map("lead_time_days")
  moq             Int?                                    // minimum order quantity
  isPreferred     Boolean         @default(false) @map("is_preferred")
  isActive        Boolean         @default(true) @map("is_active")
  validFrom       DateTime        @default(now()) @map("valid_from")
  validUntil      DateTime?       @map("valid_until")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  supplier        Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Price history for this supplier-product pair
  priceHistory    SupplierProductPriceHistory[]

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
  @@map("supplier_products")
}

/// Append-only price history for a SupplierProduct relationship
model SupplierProductPriceHistory {
  id                String          @id @default(uuid()) @db.Uuid
  supplierProductId String          @map("supplier_product_id") @db.Uuid
  unitCost          Decimal         @map("unit_cost") @db.Decimal(12, 2)
  currency          String          @default("USD")
  effectiveFrom     DateTime        @map("effective_from")
  effectiveUntil    DateTime?       @map("effective_until")
  changedBy         String?         @map("changed_by") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")

  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)

  @@index([supplierProductId])
  @@index([effectiveFrom])
  @@map("supplier_product_price_history")
}

/// Junction table: Product ↔ HalalCertificate  (M:N)
/// A certificate can cover multiple products; a product can be covered by multiple certs
model ProductCertification {
  id                  String           @id @default(uuid()) @db.Uuid
  productId           String           @map("product_id") @db.Uuid
  halalCertificateId  String           @map("halal_certificate_id") @db.Uuid
  scope               String?                                          // e.g. "manufacturing", "ingredients"
  createdAt           DateTime         @default(now()) @map("created_at")

  product             Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  halalCertificate    HalalCertificate @relation(fields: [halalCertificateId], references: [id], onDelete: Cascade)

  @@unique([productId, halalCertificateId])
  @@index([productId])
  @@index([halalCertificateId])
  @@map("product_certifications")
}

/// Taxonomy tags for products  (M:N via ProductTag)
model Tag {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  color       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  productTags ProductTag[]

  @@map("tags")
}

/// Junction table: Product ↔ Tag  (M:N)
model ProductTag {
  productId String  @map("product_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ─────────────────────────────────────────────
// WAREHOUSES  (with zones)
// ─────────────────────────────────────────────

model Warehouse {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  location           String
  address            String?
  capacity           Int?                                // total capacity in units
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")

  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  zones              WarehouseZone[]
  batchLots          BatchLot[]

  @@map("warehouses")
}

/// Physical zones/sections within a warehouse (e.g. "Cold Storage A", "Dry Goods B")
model WarehouseZone {
  id          String    @id @default(uuid()) @db.Uuid
  warehouseId String    @map("warehouse_id") @db.Uuid
  name        String
  zoneType    ZoneType  @default(GENERAL) @map("zone_type")
  capacity    Int?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventory   Inventory[]
  batchLots   BatchLot[]

  @@unique([warehouseId, name])
  @@index([warehouseId])
  @@map("warehouse_zones")
}

// ─────────────────────────────────────────────
// INVENTORY  (with batch/lot tracking)
// ─────────────────────────────────────────────

model Inventory {
  id           String         @id @default(uuid()) @db.Uuid
  productId    String         @map("product_id") @db.Uuid
  warehouseId  String         @map("warehouse_id") @db.Uuid
  zoneId       String?        @map("zone_id") @db.Uuid
  quantity     Int            @default(0)
  reservedQty  Int            @default(0) @map("reserved_qty")  // qty reserved for pending orders
  reorderLevel Int            @default(10) @map("reorder_level")
  maxLevel     Int?           @map("max_level")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zone         WarehouseZone? @relation(fields: [zoneId], references: [id])

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([zoneId])
  @@map("inventory")
}

/// Batch / Lot tracking — each physical batch of a product in a warehouse zone
model BatchLot {
  id              String         @id @default(uuid()) @db.Uuid
  productId       String         @map("product_id") @db.Uuid
  warehouseId     String         @map("warehouse_id") @db.Uuid
  zoneId          String?        @map("zone_id") @db.Uuid
  lotNumber       String         @map("lot_number")
  quantity        Int            @default(0)
  manufacturedAt  DateTime?      @map("manufactured_at") @db.Date
  expiresAt       DateTime?      @map("expires_at") @db.Date
  receivedAt      DateTime       @default(now()) @map("received_at")
  status          BatchLotStatus @default(AVAILABLE)
  /// Links back to the PO that brought this batch in
  purchaseOrderId String?        @map("purchase_order_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zone            WarehouseZone? @relation(fields: [zoneId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  movements       InventoryMovement[]

  @@unique([productId, warehouseId, lotNumber])
  @@index([productId])
  @@index([warehouseId])
  @@index([expiresAt])
  @@index([status])
  @@map("batch_lots")
}

model InventoryMovement {
  id          String                @id @default(uuid()) @db.Uuid
  productId   String                @map("product_id") @db.Uuid
  warehouseId String                @map("warehouse_id") @db.Uuid
  /// Optional: movement against a specific batch/lot
  batchLotId  String?               @map("batch_lot_id") @db.Uuid
  type        InventoryMovementType
  quantity    Int
  unitCost    Decimal?              @map("unit_cost") @db.Decimal(12, 2)
  note        String?
  /// Reference to the PO item that triggered this movement (for INBOUND)
  purchaseOrderItemId String?       @map("purchase_order_item_id") @db.Uuid
  performedBy String?               @map("performed_by") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")

  user              User?              @relation(fields: [performedBy], references: [id])
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchLot          BatchLot?          @relation(fields: [batchLotId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([productId, warehouseId])
  @@index([batchLotId])
  @@index([createdAt])
  @@index([purchaseOrderItemId])
  @@map("inventory_movements")
}

// ─────────────────────────────────────────────
// PURCHASE ORDERS  (with approval workflow)
// ─────────────────────────────────────────────

model PurchaseOrder {
  id              String              @id @default(uuid()) @db.Uuid
  supplierId      String              @map("supplier_id") @db.Uuid
  poNumber        String              @unique @map("po_number")
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmount     Decimal             @default(0) @map("total_amount") @db.Decimal(14, 2)
  currency        String              @default("USD")
  /// Expected delivery date agreed with supplier
  expectedDelivery DateTime?          @map("expected_delivery")
  /// Internal notes / terms
  notes           String?
  /// Version counter — incremented on each status change or edit
  version         Int                 @default(1)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  items           PurchaseOrderItem[]
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  shipments       Shipment[]
  approvals       PurchaseOrderApproval[]
  batchLots       BatchLot[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

/// Approval workflow steps for a PurchaseOrder.
/// Each status transition is recorded here — full audit trail.
model PurchaseOrderApproval {
  id              String              @id @default(uuid()) @db.Uuid
  purchaseOrderId String              @map("purchase_order_id") @db.Uuid
  approverId      String              @map("approver_id") @db.Uuid
  fromStatus      PurchaseOrderStatus @map("from_status")
  toStatus        PurchaseOrderStatus @map("to_status")
  comment         String?
  createdAt       DateTime            @default(now()) @map("created_at")

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  approver        User          @relation(fields: [approverId], references: [id])

  @@index([purchaseOrderId])
  @@index([approverId])
  @@map("purchase_order_approvals")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  /// Which supplier-product pricing was used at time of order
  supplierProductId String?     @map("supplier_product_id") @db.Uuid
  quantity        Int
  unitPrice       Decimal       @map("unit_price") @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(14, 2)
  receivedQty     Int           @default(0) @map("received_qty")
  createdAt       DateTime      @default(now()) @map("created_at")

  product           Product         @relation(fields: [productId], references: [id])
  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────
// SHIPMENTS  (with event log)
// ─────────────────────────────────────────────

model Shipment {
  id               String         @id @default(uuid()) @db.Uuid
  purchaseOrderId  String         @map("purchase_order_id") @db.Uuid
  trackingNumber   String         @map("tracking_number")
  carrier          String?
  origin           String
  destination      String
  status           ShipmentStatus @default(PENDING)
  estimatedArrival DateTime?      @map("estimated_arrival")
  shippedAt        DateTime?      @map("shipped_at")
  deliveredAt      DateTime?      @map("delivered_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  /// Full event log — every status change is recorded
  events           ShipmentEvent[]

  @@index([purchaseOrderId])
  @@index([status])
  @@map("shipments")
}

/// Append-only event log for a shipment.
/// Captures every status transition with timestamp and optional location/note.
model ShipmentEvent {
  id          String         @id @default(uuid()) @db.Uuid
  shipmentId  String         @map("shipment_id") @db.Uuid
  status      ShipmentStatus
  location    String?
  note        String?
  occurredAt  DateTime       @default(now()) @map("occurred_at")

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([occurredAt])
  @@map("shipment_events")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS, AUDIT, PREFERENCES
// ─────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  createdAt  DateTime    @default(now()) @map("created_at")
  user       User?       @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @map("user_id") @db.Uuid
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model UserInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  email       String
  role        UserRole  @default(STAFF)
  token       String    @unique
  invitedBy   String    @map("invited_by") @db.Uuid
  acceptedAt  DateTime? @map("accepted_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  inviter     User      @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([email])
  @@map("user_invitations")
}

model NotificationPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  certificateAlerts Boolean  @default(true) @map("certificate_alerts")
  inventoryAlerts   Boolean  @default(true) @map("inventory_alerts")
  shipmentAlerts    Boolean  @default(true) @map("shipment_alerts")
  invitationEmails  Boolean  @default(true) @map("invitation_emails")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SHIPPING
  RECEIVED
  CANCELLED
  PARTIAL
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

enum InventoryMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
  RETURN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

enum NotificationType {
  LOW_STOCK
  CERTIFICATE_EXPIRING
  CERTIFICATE_EXPIRED
  SHIPMENT_DELAYED
  SYSTEM
  COMPLIANCE_ISSUE
  BATCH_EXPIRING
}

enum ZoneType {
  GENERAL
  COLD_STORAGE
  HAZMAT
  QUARANTINE
  RETURNS
}

enum BatchLotStatus {
  AVAILABLE
  RESERVED
  QUARANTINE
  EXPIRED
  CONSUMED
}