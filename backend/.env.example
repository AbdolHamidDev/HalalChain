DATABASE_URL="postgresql://halalchain:halalchain_dev@localhost:5432/halalchain?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="15m"                  # Changed from 7d — access token TTL is now 15 minutes
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Cloudinary (used for avatar and certificate file uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Redis (used for caching and rate limiting)
REDIS_URL=""

# Email — Primary provider: Resend
# If RESEND_API_KEY is set, Resend is used. Otherwise, SMTP fallback is used.
RESEND_API_KEY=                          # Leave empty to use SMTP fallback
EMAIL_FROM="noreply@halalchain.app"      # Sender address for all outbound emails

# Email — Fallback provider: SMTP (used when RESEND_API_KEY is absent)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
