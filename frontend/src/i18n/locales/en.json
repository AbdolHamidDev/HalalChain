    "features": {
      "title": "From CRUD to intelligent compliance monitoring",
      "subtitle": "HalalChain is not just a management system. It's a compliance-driven automation platform that monitors, alerts, and scores your supply chain health.",
      "items": {
        "traceability": {
          "title": "Product Traceability",
          "description": "End-to-end tracking from supplier to consumer with QR code verification. Public traceability pages require no login."
        },
        "compliance": {
          "title": "Compliance Monitoring",
          "description": "Automated certificate expiry detection, expired certificate alerts, compliance issue tracking, and a transparent compliance score (0-100) with explainable factors."
        },
        "automation": {
          "title": "Automation Engine",
          "description": "Four automated rules run daily: certificate expiry alerts, expired certificate escalation, low inventory warnings, and shipment delay detection. Idempotent with built-in duplicate prevention."
        },
        "certifications": {
          "title": "Halal Certifications",
          "description": "Centralize certification management with digital document storage, expiry monitoring, file uploads to Cloudinary, and automated renewal reminders."
        },
        "analytics": {
          "title": "Analytics & Reporting",
          "description": "Comprehensive dashboards, date-range analytics for inventory, POs, shipments, certificates, and exportable reports in CSV/XLSX/PDF formats."
        },
        "notifications": {
          "title": "Real-time Notifications",
          "description": "In-app alerts via Server-Sent Events for low stock, certificate events, and shipment delays. Fire-and-forget email delivery via Resend or SMTP with exponential retry."
        }
      }
    },
    "workflow": {
      "title": "Traceability Flow",
      "subtitle": "From supplier registration to consumer verification, every step is tracked, certified, and verifiable through QR codes.",
      "steps": {
        "supplier": {
          "label": "Supplier",
          "description": "Onboard halal-certified suppliers with documentation"
        },
        "product": {
          "label": "Product",
          "description": "Log products with SKU, batch, and halal status"
        },
        "certification": {
          "label": "Certification",
          "description": "Attach certificates with automated expiry monitoring"
        },
        "warehouse": {
          "label": "Warehouse",
          "description": "Manage inventory with reorder level alerts"
        },
        "shipment": {
          "label": "Shipment",
          "description": "Track shipments with delay detection"
        },
        "consumer": {
          "label": "Consumer",
          "description": "Verify authenticity via QR code — no login required"
        }
      },
      "explanation": {
        "title": "Full supply chain transparency with compliance baked in",
        "p1": "HalalChain creates a digital thread connecting every entity in your supply chain. Each product batch receives a unique QR code that follows it from raw materials to the end consumer, enabling instant verification.",
        "p2": "Suppliers are onboarded with verifiable halal certifications. The platform automatically monitors certificate expiry dates and escalates expired certificates with high-severity alerts to compliance teams.",
        "p3": "The automation engine runs daily checks: detecting overdue shipments, scanning inventory for low-stock items, and generating compliance scores that give management a single KPI for supply chain health."
      }
    },
    "compliance": {
      "title": "Automated Compliance Monitoring",
      "subtitle": "The platform continuously monitors your supply chain health and alerts you to risks before they become problems.",
      "items": {
        "certificateExpiry": {
          "title": "Certificate Expiry Detection",
          "subtitle": "Scans all certificates daily. Detects expirations within 30 days and sends alerts to managers and admins via in-app notification and email."
        },
        "certificateExpired": {
          "title": "Expired Certificate Escalation",
          "subtitle": "Identifies already-expired certificates and creates high-severity compliance issues. Triggers immediate notifications to responsible teams."
        },
        "lowInventory": {
          "title": "Low Inventory Detection",
          "subtitle": "Compares current stock against reorder levels. Generates alerts suggesting replenishment actions without automatically placing orders."
        },
        "shipmentDelay": {
          "title": "Shipment Delay Detection",
          "subtitle": "Automatically detects shipments past their estimated arrival date that haven't been marked delivered. Prevents duplicate daily alerts."
        },
        "complianceScore": {
          "title": "Compliance Scoring",
          "subtitle": "A transparent 0-100 score based on 5 factors: expired certs (-30pt), expiring certs (-15pt), delayed shipments (up to -20pt), low inventory (up to -15pt), and certificate coverage (up to -20pt). Each deduction is explainable."
        },
        "realTimeAlerts": {
          "title": "Real-time Alerts",
          "subtitle": "All automation events stream via Server-Sent Events to the dashboard instantly. Email delivery is fire-and-forget with 3 retry attempts and exponential backoff."
        }
      },
      "scoreNote": "See the Compliance Score KPI on your dashboard. Every deduction is transparent — hover or click to see why each point was deducted."
    },
    "verificationDemo": {
      "title": "Public QR Code Verification",
      "subtitle": "End consumers can verify product authenticity instantly by scanning the QR code on packaging. No account or login required.",
      "steps": {
        "qrScanning": {
          "title": "QR Code Scanning",
          "description": "Each product has a unique QR code on packaging. Consumers scan with any smartphone camera — no app required."
        },
        "productVerification": {
          "title": "Product Details",
          "description": "The public portal displays product origin, supplier, batch number, and halal certification status instantly."
        },
        "certificateValidation": {
          "title": "Certificate Validation",
          "description": "View all attached halal certificates with certifying bodies, issue dates, and expiry information at a glance."
        },
        "shipmentHistory": {
          "title": "Supply Chain Journey",
          "description": "Track the complete journey from supplier through warehouses to retailer with timestamps and location data."
        }
      },
      "cta": {
        "tryText": "Try it now with a real seeded product from our database",
        "button": "Verify Organic Coconut Milk"
      }
    },
